{
  "family": "inventory-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "inventory-service",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/inventory-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "OTEL_SERVICE_NAME",              "value": "inventory-service" },
        { "name": "OTEL_SERVICE_VERSION",           "value": "1.0.0" },
        { "name": "OTEL_RESOURCE_ATTRIBUTES",       "value": "deployment.environment=production,service.namespace=warehouse" },
        { "name": "OTEL_EXPORTER_OTLP_ENDPOINT",   "value": "http://<OTEL_GATEWAY_HOST>:4318" },
        { "name": "OTEL_EXPORTER_OTLP_PROTOCOL",   "value": "http/protobuf" },
        { "name": "OTEL_TRACES_EXPORTER",           "value": "otlp" },
        { "name": "OTEL_METRICS_EXPORTER",          "value": "otlp" },
        { "name": "OTEL_LOGS_EXPORTER",             "value": "otlp" },
        { "name": "OTEL_PYTHON_LOG_CORRELATION",    "value": "true" },
        { "name": "OTEL_PYTHON_LOG_LEVEL",          "value": "info" },
        { "name": "OTEL_METRIC_EXPORT_INTERVAL",    "value": "15000" },
        { "name": "OTEL_TRACES_SAMPLER",            "value": "always_on" },
        { "name": "OTEL_PROPAGATORS",               "value": "tracecontext,baggage" },
        { "name": "SELF_URL",                       "value": "http://localhost:5000" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/inventory-service",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:5000/ || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
